# Ignorar ambientes virtuais locais
.venv/
venv/
ENV/
# A versão da imagem vem do --build-arg APP_VERSION, não de um .env assado.
.env
.env.*

# Ignorar caches do Python e ferramentas
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Ignorar arquivos do Git e IDEs
.git/
.gitignore
.idea/
.vscode/

# Ignorar documentações e logs locais
README.md
*.log
